# ── Application ──
APP_NAME=StadiumSync
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Security ──
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=240

# ── Database (Neon Serverless PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://user:password@host/stadium_sync
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Google Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash


# ── Telegram Bots ──
TELEGRAM_FAN_BOT_TOKEN=your-fan-bot-token
TELEGRAM_VOLUNTEER_BOT_TOKEN=your-volunteer-bot-token
TELEGRAM_WEBHOOK_BASE_URL=https://your-backend.onrender.com

# ── Rate Limiting ──
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=20/minute
RATE_LIMIT_UPLOAD=10/minute

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173","https://your-frontend.vercel.app"]

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
