# ── Application ──
APP_NAME=StadiumSync
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Security ──
SECRET_KEY=generate-a-32-character-or-longer-secret-for-production
TICKET_QR_SIGNING_KEY=generate-a-separate-32-character-or-longer-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=240

# ── Google Cloud ──
ALLOW_AI_MOCK_FALLBACK=true
ALLOW_DEMO_FEATURES=true

# ── Database (Neon Serverless PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://user:password@host/stadium_sync
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Google Gemini AI ──
GEMINI_API_KEY_1=your-gemini-api-key
GEMINI_API_KEY_3=optional-second-gemini-api-key
NVIDIA_API_KEY=optional-nvidia-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Telegram Bots ──
TELEGRAM_FAN_BOT_TOKEN=your-fan-bot-token
TELEGRAM_VOLUNTEER_BOT_TOKEN=your-volunteer-bot-token
TELEGRAM_WEBHOOK_BASE_URL=https://your-backend-url.run.app

# ── Rate Limiting ──
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=20/minute
RATE_LIMIT_UPLOAD=10/minute
IOT_API_KEY=generate-a-32-character-or-longer-iot-api-key

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173","https://your-frontend.web.app"]

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
